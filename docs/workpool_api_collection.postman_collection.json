                                "auth",
                                "register"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Verificar Correo",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/verify-email?token=AQUÍ_VA_EL_UUID_DE_LA_BD",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "verify-email"
                            ],
                            "query": [
                                {
                                    "key": "token",
                                    "value": "AQUÍ_VA_EL_UUID_DE_LA_BD",
                                    "description": "Token copiado directo de tu base de datos o consola para simular la verificación."
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Iniciar Sesión (Login)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Login Exitoso\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.eql(true);",
                                    "    if(jsonData.data && jsonData.data.token) {",
                                    "        pm.environment.set(\"token\", jsonData.data.token);",
                                    "        console.log(\"Token guardado automáticamente en el entorno.\");",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"gino.test@gmail.com\",\n    \"password\": \"Password1234\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
