            "item": [
                {
                    "name": "Registrar Usuario",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"firstName\": \"Gino\",\n    \"lastName\": \"Daza\",\n    \"email\": \"gino.test@gmail.com\",\n    \"phoneNumber\": \"987654321\",\n    \"dni\": \"12345678\",\n    \"birthDate\": \"1995-06-15\",\n    \"password\": \"Password1234\",\n    \"confirmPassword\": \"Password1234\",\n    \"termsAccepted\": true\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
